        {
            "name": "Send Message",
            "request": {
                "method": "POST",
                "header": [
                    {
                        "key": "Content-Type",
                        "value": "application/json"
                    }
                ],
                "body": {
                    "mode": "raw",
                    "raw": "{\n  \"senderId\": \"user1\",\n  \"receiverId\": \"user2\",\n  \"content\": \"Hello!\"\n}"
                },
                "url": {
                    "raw": "http://localhost:8080/api/messages/send",
                    "protocol": "http",
                    "host": [
                        "localhost"
                    ],
                    "port": "8080",
                    "path": [
                        "api",
                        "messages",
                        "send"
                    ]
                }
            }
        },
        {
            "name": "Get Conversation Between Two Users",
            "request": {
                "method": "GET",
                "header": [],
                "url": {
                    "raw": "http://localhost:8080/api/messages/conversation/{{user1Id}}/{{user2Id}}?page=0&size=20",
                    "protocol": "http",
                    "host": [
                        "localhost"
                    ],
                    "port": "8080",
                    "path": [
                        "api",
                        "messages",
                        "conversation",
                        "{{user1Id}}",
                        "{{user2Id}}"
                    ],
                    "query": [
                        {
                            "key": "page",
                            "value": "0"
                        },
                        {
                            "key": "size",
                            "value": "20"
                        }
                    ]
                }
            }
        },
        {
            "name": "Get Chat Room Messages",
            "request": {
                "method": "GET",
